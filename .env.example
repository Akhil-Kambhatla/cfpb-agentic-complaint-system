# LLM API Keys (at least one required)
# Get Anthropic key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Fallback: Get OpenAI key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Model selection
ANTHROPIC_MODEL=claude-sonnet-4-20250514
OPENAI_MODEL=gpt-4o

# Data paths
CFPB_DATA_PATH=data/raw/complaints.csv
SAMPLE_SIZE=10000
TEST_SIZE=1000

# Slack Integration (all optional — system works without Slack)
# Main webhook: high-risk escalation alerts
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
# Risk gap threshold above which escalation alert fires (default: 0.2)
SLACK_RISK_THRESHOLD=0.2
# Per-team routing webhooks
SLACK_WEBHOOK_COMPLIANCE=https://hooks.slack.com/services/your/webhook/url
SLACK_WEBHOOK_BILLING_DISPUTES=https://hooks.slack.com/services/your/webhook/url
SLACK_WEBHOOK_FRAUD=https://hooks.slack.com/services/your/webhook/url
SLACK_WEBHOOK_CUSTOMER_SERVICE=https://hooks.slack.com/services/your/webhook/url
SLACK_WEBHOOK_LEGAL=https://hooks.slack.com/services/your/webhook/url
SLACK_WEBHOOK_EXECUTIVE_ESCALATION=https://hooks.slack.com/services/your/webhook/url
